// Roomly – Prisma Schema
// Stack: PostgreSQL 16 + Prisma 5
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum ReservationStatus {
  PENDING_PAYMENT  // reserva creada, esperando pago de seña/total
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum PaymentType {
  DEPOSIT  // seña del 15%
  FULL     // total completo
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  OUT_OF_ORDER
}

enum HousekeepingStatus {
  PENDING
  IN_PROGRESS
  DONE
  INSPECTED
}

enum Channel {
  WHATSAPP
  WEB
  PHONE
  OTA
  DIRECT
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

// ─────────────────────────────────────────────
// Core entities
// ─────────────────────────────────────────────

model Hotel {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  address   String?
  phone     String?
  email     String?
  timezone  String   @default("America/Argentina/Buenos_Aires")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roomTypes    RoomType[]
  rooms        Room[]
  guests       Guest[]
  reservations Reservation[]
  ratePlans    RatePlan[]
}

model RoomType {
  id          String   @id @default(cuid())
  hotelId     String
  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name        String
  description String?
  maxGuests   Int      @default(2)
  amenities   String[]

  rooms     Room[]
  ratePlans RatePlan[]

  @@index([hotelId])
}

model Room {
  id      String     @id @default(cuid())
  hotelId String
  hotel   Hotel      @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  typeId  String
  type    RoomType   @relation(fields: [typeId], references: [id])
  number  String
  floor   Int?
  status  RoomStatus @default(AVAILABLE)
  notes   String?

  reservations      Reservation[]
  housekeepingTasks HousekeepingTask[]

  @@unique([hotelId, number])
  @@index([hotelId])
}

model RatePlan {
  id            String   @id @default(cuid())
  hotelId       String
  hotel         Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  typeId        String
  type          RoomType @relation(fields: [typeId], references: [id])
  name          String
  pricePerNight Decimal  @db.Decimal(10, 2)
  validFrom     DateTime @db.Date
  validTo       DateTime @db.Date
  minNights     Int      @default(1)

  reservations Reservation[]

  @@index([hotelId, typeId])
}

model Guest {
  id        String   @id @default(cuid())
  hotelId   String
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  email     String?
  dni       String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservations         Reservation[]
  conversationSessions ConversationSession[]
  messages             Message[]

  @@unique([hotelId, phone])
  @@index([hotelId])
}

model Reservation {
  id         String            @id @default(cuid())
  hotelId    String
  hotel      Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomId     String
  room       Room              @relation(fields: [roomId], references: [id])
  guestId    String
  guest      Guest             @relation(fields: [guestId], references: [id])
  // Titular de ESTA reserva. Se captura al crearla y es independiente del
  // nombre del Guest (que es el contacto de WhatsApp, único por teléfono).
  // Permite que un mismo número reserve a nombre de personas distintas.
  guestName  String?
  ratePlanId String?
  ratePlan   RatePlan?         @relation(fields: [ratePlanId], references: [id])

  code       String            @unique
  status     ReservationStatus @default(CONFIRMED)
  channel    Channel           @default(WHATSAPP)

  checkIn    DateTime @db.Date
  checkOut   DateTime @db.Date
  numGuests  Int      @default(1)
  totalPrice Decimal? @db.Decimal(10, 2)
  notes      String?

  calendarEventId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  housekeepingTasks HousekeepingTask[]
  auditLogs         AuditLog[]
  payment           Payment?

  // IMPORTANT: double-booking exclusion constraint is added via raw SQL
  // in the migration file. See prisma/migrations/*/migration.sql

  @@index([hotelId])
  @@index([roomId])
  @@index([guestId])
  @@index([code])
}

model HousekeepingTask {
  id            String             @id @default(cuid())
  roomId        String
  room          Room               @relation(fields: [roomId], references: [id])
  reservationId String?
  reservation   Reservation?       @relation(fields: [reservationId], references: [id])
  status        HousekeepingStatus @default(PENDING)
  notes         String?
  scheduledFor  DateTime
  completedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([roomId])
}

model ConversationSession {
  id        String   @id @default(cuid())
  guestId   String?
  guest     Guest?   @relation(fields: [guestId], references: [id])
  channel   Channel  @default(WHATSAPP)
  phone     String
  context   Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
}

model AuditLog {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  action        String
  before        Json?
  after         Json?
  performedBy   String      @default("system")
  createdAt     DateTime    @default(now())

  @@index([reservationId])
}

// Registro de pagos de Mercado Pago asociados a reservas.
// Una reserva puede tener a lo sumo un pago (seña o total).
model Payment {
  id             String        @id @default(cuid())
  hotelId        String
  reservationId  String        @unique
  reservation    Reservation   @relation(fields: [reservationId], references: [id])
  mpPreferenceId String?       // ID de la preferencia de MP (antes de pagar)
  mpPaymentId    String?       // ID del pago en MP (después de pagar)
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("ARS")
  status         PaymentStatus @default(PENDING)
  paymentType    PaymentType
  expiresAt      DateTime      // deadline de 24hs; pasado esto se auto-cancela
  notifiedAt     DateTime?     // cuándo se envió el WhatsApp de confirmación
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([reservationId])
  @@index([mpPaymentId])
}

// Transcripción de la conversación de WhatsApp. Se guarda el hilo completo por
// teléfono (cada mensaje una fila) para poder reconstruir el chat y usarlo luego
// en mejoras del sistema. La vista "por reserva" se calcula como un recorte
// temporal alrededor de Reservation.createdAt (ver conversation.service.ts).
model Message {
  id          String           @id @default(cuid())
  hotelId     String?
  phone       String
  guestId     String?
  guest       Guest?           @relation(fields: [guestId], references: [id])
  direction   MessageDirection
  content     String
  channel     Channel          @default(WHATSAPP)
  waTimestamp DateTime?
  createdAt   DateTime         @default(now())

  @@index([phone])
  @@index([phone, createdAt])
}
