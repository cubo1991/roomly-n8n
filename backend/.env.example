# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://roomly:roomly_password@localhost:5433/roomly"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── NextAuth v5 ─────────────────────────────────────────────────────────────
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Admin credentials ───────────────────────────────────────────────────────
# Generate hash: node -e "const b=require('bcryptjs'); console.log(b.hashSync('yourpassword', 10))"
ADMIN_EMAIL="admin@hotel.com"
ADMIN_PASSWORD_HASH="$2b$10$YourHashHere"

# ─── n8n integration ─────────────────────────────────────────────────────────
# Must match N8N_WEBHOOK_SECRET in n8n environment
N8N_WEBHOOK_SECRET="a-long-random-secret-string"

# ─── Google Calendar ─────────────────────────────────────────────────────────
# Cuenta de servicio de Google Cloud con acceso al calendario
# Dejá vacío para deshabilitar la integración
GOOGLE_SERVICE_ACCOUNT_EMAIL="roomly@your-project.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID="primary"   # o el ID del calendario específico (ej: abc123@group.calendar.google.com)

# ─── Mercado Pago ────────────────────────────────────────────────────────────
# Sandbox: APP_USR-... (de mercadopago.com.ar → Desarrolladores → Credenciales)
# Producción: reemplazar por el token real cuando se pase a live
MP_ACCESS_TOKEN="APP_USR-your-access-token-here"
# Secret para verificar la firma HMAC de los webhooks de MP (opcional pero recomendado)
MP_WEBHOOK_SECRET="a-random-secret-for-mp-webhooks"

# ─── WhatsApp (notificación de pago confirmado) ───────────────────────────────
# Mismo phoneNumberId y token que usa n8n — necesarios para notificar desde el backend
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_ACCESS_TOKEN="your-whatsapp-access-token"

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
