    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst mensaje = item.messages?.[0];\nif (!mensaje || mensaje.type !== 'text') return [];\nconst phoneNumberId = item.metadata?.phone_number_id ?? '';\nconst from = mensaje.from ?? '';\nconst messageText = mensaje.text?.body ?? '';\nconst timestamp = mensaje.timestamp ?? Math.floor(Date.now() / 1000);\nif (!messageText.trim()) return [];\nconst codigoRML = 'RML-' + String(Math.floor(Math.random() * 10000)).padStart(4, '0');\nreturn [{ json: { phoneNumberId, from, messageText, timestamp, codigoRML } }];\n"
      },
      "type": "n8n-nodes-base.code",
