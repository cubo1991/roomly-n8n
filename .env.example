# Copiá este archivo como .env y completá los valores
# cp .env.example .env

# ── ngrok ──────────────────────────────────────────────
N8N_HOST=your-subdomain.ngrok-free.app
WEBHOOK_URL=https://your-subdomain.ngrok-free.app

# ── WhatsApp ───────────────────────────────────────────
# Número destino con código de país, sin + ni espacios
WHATSAPP_RECIPIENT=5491112345678

# ── PostgreSQL ─────────────────────────────────────────
POSTGRES_USER=roomly
POSTGRES_PASSWORD=roomly_password
POSTGRES_DB=roomly

# ── Backend (Next.js) ──────────────────────────────────
# Generar: openssl rand -base64 32
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@hotel.com
# Generar hash: node -e "const b=require('bcryptjs'); console.log(b.hashSync('tupassword', 10))"
# Escapar $ con \$ para evitar que Next.js los expanda
ADMIN_PASSWORD_HASH=\$2b\$10\$YourHashHere
N8N_WEBHOOK_SECRET=a-long-random-secret-string

# ── n8n → Backend ──────────────────────────────────────
# URL del backend tal como lo ve el contenedor n8n
# Windows/Mac Docker Desktop: host.docker.internal
# Linux Docker: 172.17.0.1 (o la IP del bridge)
BACKEND_URL=http://host.docker.internal:3000
# ID del hotel (obtenido del seed: npm run db:seed)
HOTEL_ID=cmph1h1f20000d03cse27mpf9
